# Project Configuration
PROJECT_NAME="HELIOSCADA Backend"
API_V1_STR="/api/v1"

# Database Configuration (PostgreSQL)
# For running inside docker-compose: postgresql+asyncpg://postgres:postgres@db:5432/helioscada
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/helioscada"

# MQTT Configuration
# For running inside docker-compose: MQTT_BROKER="mosquitto"
MQTT_BROKER="localhost"
MQTT_PORT=1883
MQTT_TOPIC_TELEMETRY="laboratorium/scada/pv_kit/telemetry"
MQTT_TOPIC_STATUS_RELAY="laboratorium/scada/pv_kit/status/relay"
