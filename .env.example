# Project Configuration
PROJECT_NAME="HELIOSCADA Backend"
API_V1_STR="/api/v1"

# API Server Configuration
API_HOST="0.0.0.0"
API_PORT=8000
API_CORS="*"

# Database Configuration (PostgreSQL)
# Note: For running inside docker-compose, use DB_HOST="db"
DB_HOST="localhost"
DB_PORT=5432
DB_USER="postgres"
DB_PASSWORD="postgres"
DB_NAME="helioscada"

# Optional Database URL override (takes precedence if set)
# DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/helioscada"

# MQTT Configuration
# Note: For running inside docker-compose, use MQTT_BROKER="mosquitto"
MQTT_BROKER="localhost"
MQTT_PORT=1883
MQTT_TOPIC_TELEMETRY="laboratorium/scada/pv_kit/telemetry"
MQTT_TOPIC_STATUS_RELAY="laboratorium/scada/pv_kit/status/relay"

# Bridge Ingestion API URL
# Note: For running inside docker-compose, use API_URL="http://api:8000/api/v1"
API_URL="http://localhost:8000/api/v1"
